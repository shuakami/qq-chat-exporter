{
  "name": "qq-chat-exporter",
  "plugin": "QQ 聊天记录导出",
  "version": "5.5.80",
  "description": "导出 QQ 聊天记录为 HTML / JSON / TXT / Excel，支持时间筛选、批量任务、定时任务、表情图片语音视频资源处理、合并转发展开等。",
  "main": "index.mjs",
  "type": "module",
  "icon": "icon.png",
  "homepage": "https://github.com/shuakami/qq-chat-exporter",
  "repository": {
    "type": "git",
    "url": "https://github.com/shuakami/qq-chat-exporter.git"
  },
  "napcat": {
    "tags": [
      "工具"
    ],
    "minVersion": "4.14.0",
    "homepage": "https://github.com/shuakami/qq-chat-exporter"
  },
  "scripts": {
    "gen:overlay": "node tools/create-overlay-runtime.cjs",
    "typecheck": "tsc --noEmit --allowJs --checkJs --module NodeNext --moduleResolution NodeNext --target ES2022 --types node index.mjs runtime/ApiLauncher.mjs runtime/rustBridge.mjs",
    "pretest": "npm run gen:overlay",
    "test": "node __tests__/scripts/run-tests.mjs \"__tests__/**/*.test.ts\"",
    "test:unit": "node __tests__/scripts/run-tests.mjs \"__tests__/unit/**/*.test.ts\" \"__tests__/smoke.test.ts\"",
    "test:entrypoint": "node test-plugin.mjs",
    "test:runtime": "node test-plugin-full.mjs",
    "test:context": "node test-plugin-init-context.mjs",
    "mock:server": "node __tests__/scripts/mock-server.mjs"
  },
  "keywords": [
    "napcat",
    "plugin",
    "qq",
    "chat",
    "exporter",
    "onebot"
  ],
  "author": "shuakami",
  "dependencies": {},
  "devDependencies": {
    "tsx": "^4.19.2",
    "@types/node": "^22.9.1",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
