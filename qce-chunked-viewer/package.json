{
  "name": "qce-chunked-viewer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "HyperScroll-powered viewer for QCE chunked HTML exports. Builds into a single assets/app.js consumed by ModernHtmlTemplates / qq-chat-export-core.",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/bundle.mjs",
    "sync": "node scripts/sync-templates.mjs",
    "test": "node --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui-components/react": "^1.0.0-beta.4",
    "@base-ui/react": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.8",
    "react-day-picker": "^9.8.0",
    "react-dom": "^19.2.8",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  }
}
